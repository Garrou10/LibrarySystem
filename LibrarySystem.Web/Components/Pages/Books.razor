@page "/books"
@rendermode InteractiveServer
@using LibrarySystem.Core
@inject IBookRepository BookRepo

<PageTitle>Boklista</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📚 Bibliotekets Böcker</h1>
    <a href="/add-book" class="btn btn-success">➕ Lägg till ny bok</a>
</div>

<div class="mb-3">
    <div class="input-group">
        <input type="text" class="form-control" placeholder="Sök på titel eller författare..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
        <button class="btn btn-outline-secondary" @onclick="HandleSearch">🔍 Sök</button>
    </div>
</div>

@if (books == null)
{
    <p><em>Laddar böcker från databasen...</em></p>
}
else if (!books.Any())
{
    <div class="alert alert-info">Det finns inga böcker i databasen än. Dags att lägga till några!</div>
}
else
{
    <table class="table table-striped table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>ISBN</th>
                <th>Titel</th>
                <th>Författare</th>
                <th>År</th>
                <th>Status</th>
                <th>Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.ISBN</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>
                        @if (editingBookId == book.Id)
                        {
                            <input type="number" @bind="book.PublishedYear" class="form-control form-control-sm" style="width: 100px;" />
                        }
                        else
                        {
                            @book.PublishedYear
                        }
                    </td>
                    <td>
                        @if (book.IsAvailable)
                        {
                            <span class="badge bg-success">🟢 Tillgänglig</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">🔴 Utlånad</span>
                        }
                    </td>
                    <td>
                        @if (editingBookId == book.Id)
                        {
                            <button class="btn btn-primary btn-sm me-1" @onclick="() => SaveBook(book)">Spara</button>
                            <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Avbryt</button>
                        }
                        else
                        {
                            <button class="btn btn-warning btn-sm" @onclick="() => StartEdit(book.Id)">Redigera</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IEnumerable<Book>? books;
    private string searchTerm = "";
    private int? editingBookId;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        books = await BookRepo.GetAllAsync();
    }

    private void StartEdit(int id)
    {
        editingBookId = id;
        StateHasChanged();
    }

    private void CancelEdit()
    {
        editingBookId = null;
    }

    private async Task SaveBook(Book book)
    {
        await BookRepo.UpdateAsync(book);
        editingBookId = null;
        await LoadBooks(); 
    }

    private async Task HandleSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadBooks();
        }
        else
        {
            books = await BookRepo.SearchAsync(searchTerm);
        }
    }
}